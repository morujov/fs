APP_NAME="Números ES"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://numeros-es.test

# Основной рынок — Испания. Fallback на es, а не en: если строка не
# переведена, испанцу лучше увидеть испанский, чем английский.
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------
# База данных
# ---------------------------------------------------------------------
# Локально: DBngin, MySQL 8, порт обычно 3306.
# На Bluehost: MySQL 5.7.44 (проверено 14.07.2026) — версии расходятся,
# поэтому не используем ничего из MySQL 8: ни оконных функций, ни CHECK.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=numeros_es
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------------
# Сессии, кэш, очереди
# ---------------------------------------------------------------------
# На Bluehost нет Redis и нет supervisor. Поэтому database/file и cron.
# Держим те же драйверы локально, чтобы прод не преподносил сюрпризов.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ---------------------------------------------------------------------
# Google OAuth — единственный способ входа. Паролей в системе нет.
# ---------------------------------------------------------------------
# Завести в Google Cloud Console → APIs & Services → Credentials.
# Scopes только openid/email/profile — это «базовый вход»: не требует
# аудита Google и не требует публичной политики конфиденциальности
# на этапе Testing.
#
# Для разработки: статус Testing, redirect на http://127.0.0.1:8000 —
# домен и юр. страницы не нужны, до 100 тестовых пользователей.
# Перед публикацией: Política de privacidad обязательна, redirect только
# HTTPS на боевой домен, localhost из прод-клиента убрать.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ---------------------------------------------------------------------
# SMS для OTP — подтверждение владения продаваемым номером
# ---------------------------------------------------------------------
# log  — коды пишутся в storage/logs/laravel.log, SMS не уходят (dev)
# labsmobile / messagebird — боевые драйверы
# Держите log, пока не начнёте тестировать на реальных номерах:
# каждая SMS стоит ~0.05 €, и цикл отладки легко съест бюджет.
SMS_DRIVER=log
SMS_FROM="NumerosES"
LABSMOBILE_USERNAME=
LABSMOBILE_TOKEN=

# ---------------------------------------------------------------------
# Почта
# ---------------------------------------------------------------------
# НЕ используйте SMTP Bluehost — письма уйдут в спам.
# Нужен внешний провайдер + SPF/DKIM/DMARC на домене.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@example.es"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------
# Антибот
# ---------------------------------------------------------------------
# Cloudflare Turnstile, а не reCAPTCHA: reCAPTCHA гонит данные в Google
# без правового основания и в ЕС это проблема с AEPD.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

VITE_APP_NAME="${APP_NAME}"
